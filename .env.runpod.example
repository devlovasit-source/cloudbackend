OLLAMA_URL=http://127.0.0.1:11434/api
OLLAMA_VISION_URL=http://127.0.0.1:11435/api

# Text model chain
OLLAMA_TEXT_MODEL=phi3:latest
OLLAMA_PIN_TEXT_MODEL=true
OLLAMA_MODEL_FALLBACKS=
ALLOW_HEAVY_MODELS=false
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=192
OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.85
OLLAMA_REPEAT_PENALTY=1.15
OLLAMA_MAX_PROMPT_CHARS=7000
OLLAMA_MAX_INFLIGHT_REQUESTS=2
OLLAMA_QUEUE_WAIT_SECONDS=6

# Vision model chain
OLLAMA_VISION_MODEL=llama3.2-vision:latest
OLLAMA_VISION_MODEL_FALLBACKS=llama3.2-vision:latest,llava:7b
OLLAMA_VISION_TIMEOUT_SECONDS=180
OLLAMA_VISION_NUM_CTX=1024
ENABLE_LOCAL_REMBG_FALLBACK=false

# RunPod background removal endpoints
RUNPOD_BG_SINGLE_URL=https://<your-pod>.proxy.runpod.net/remove-bg
RUNPOD_BG_BATCH_URL=https://<your-pod>.proxy.runpod.net/remove-bg/batch
RUNPOD_BG_TIMEOUT_SECONDS=20

# Chat pod should usually disable heavy local services and call dedicated pods.
ENABLE_VISION=false
ENABLE_BG_REMOVER=false
